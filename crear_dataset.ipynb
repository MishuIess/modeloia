import pandas as pd
import random

# =====================================================
# Configuración para reproducibilidad
# =====================================================

random.seed(42)

# =====================================================
# Valores posibles
# =====================================================

generos = [
    "Male",
    "Female"
]

niveles_actividad = [
    "Low",
    "Medium",
    "High"
]

niveles_estres = [
    "Low",
    "Medium",
    "High"
]

# =====================================================
# Lista donde se almacenarán los registros
# =====================================================

datos = []

# =====================================================
# Generación de 5000 registros
# =====================================================

for i in range(5000):

    # -----------------------------------------
    # Variables categóricas
    # -----------------------------------------

    genero = random.choice(generos)

    actividad_fisica = random.choice(niveles_actividad)

    estres = random.choice(niveles_estres)

    # -----------------------------------------
    # Edad
    # -----------------------------------------

    edad = random.randint(13, 19)

    # -----------------------------------------
    # Horas de sueño
    # -----------------------------------------

    horas_sueno = round(random.uniform(4.0, 10.0), 1)

    # -----------------------------------------
    # Uso de redes sociales
    # -----------------------------------------

    redes_sociales = round(random.uniform(1.0, 12.0), 1)

    # -----------------------------------------
    # Rendimiento académico
    # -----------------------------------------

    rendimiento = round(random.uniform(4.0, 10.0), 1)

    # =================================================
    # Reglas coherentes para dar realismo
    # =================================================

    # Mucho estrés reduce sueño

    if estres == "High":
        horas_sueno -= round(random.uniform(1.0, 2.0), 1)

    # Actividad física mejora bienestar

    if actividad_fisica == "High":
        horas_sueno += round(random.uniform(0.5, 1.5), 1)

    # Redes sociales excesivas reducen rendimiento

    if redes_sociales > 8:
        rendimiento -= round(random.uniform(0.5, 2.0), 1)

    # -----------------------------------------
    # Limitar rangos
    # -----------------------------------------

    if horas_sueno > 12:
        horas_sueno = 12

    if horas_sueno < 1:
        horas_sueno = 1

    if rendimiento > 10:
        rendimiento = 10

    if rendimiento < 0:
        rendimiento = 0

    # =================================================
    # Variable objetivo
    # =================================================

    probabilidad = random.random()

    riesgo_salud_mental = "Low"

    # Casos claramente de riesgo

    if horas_sueno < 5:
        riesgo_salud_mental = "High"

    elif redes_sociales > 9:
        riesgo_salud_mental = "High"

    elif estres == "High" and probabilidad > 0.3:
        riesgo_salud_mental = "High"

    # Casos moderados

    elif rendimiento < 6 and probabilidad > 0.5:
        riesgo_salud_mental = "Medium"

    elif actividad_fisica == "Low" and probabilidad > 0.5:
        riesgo_salud_mental = "Medium"

    # Casos saludables

    elif horas_sueno > 8 and actividad_fisica == "High":
        riesgo_salud_mental = "Low"

    # =================================================
    # Guardar registro
    # =================================================

    datos.append([
        edad,
        genero,
        horas_sueno,
        redes_sociales,
        actividad_fisica,
        estres,
        rendimiento,
        riesgo_salud_mental
    ])

# =====================================================
# Crear DataFrame
# =====================================================

df = pd.DataFrame(
    datos,
    columns=[
        "Age",
        "Gender",
        "Sleep_Hours",
        "Social_Media_Hours",
        "Physical_Activity",
        "Stress_Level",
        "Academic_Performance",
        "Mental_Health_Risk"
    ]
)

# =====================================================
# Guardar CSV
# =====================================================

df.to_csv(
    "data/teen_mental_health.csv",
    index=False
)

# =====================================================
# Mostrar información
# =====================================================

print(df.head())

print("\nTamaño del dataset:")
print(df.shape)

print("\nDistribución de riesgo:")
print(df["Mental_Health_Risk"].value_counts())
